generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// FTS5 Virtual Tables (managed in src/database/task-record.ts)

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      UserAccount[]
}

model UserAccount {
  id          String   @id @default(uuid())
  userId      String
  provider    String   // 'telegram', 'discord', 'web'
  providerId  String   // platform-specific ID (e.g., Telegram chatId)
  username    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
}

model TaskQueue {
  id              String   @id @default(uuid())
  userId          String
  taskRecordId    String
  scheduledJobId  String?
  status          String   @default("pending")
  priority        Int      @default(0)
  workerId        String?
  attempts        Int      @default(0)
  maxAttempts     Int      @default(3)
  error           String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, priority, createdAt])
  @@index([userId, taskRecordId, status])
  @@index([scheduledJobId])
}

model TaskRecord {
  id                   String   @id @default(uuid())
  userId               String
  status               String   @default("pending")
  requiresConfirmation Boolean  @default(false)
  metadata             String?  // JSON
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  history              TaskHistory[]

  @@index([userId, id])
  @@index([userId, status])
}

model TaskHistory {
  id           String   @id @default(uuid())
  taskRecordId String
  role         String
  content      String
  reasoningContent String?
  iteration    Int?
  toolCallId   String?
  toolCalls    String?  // JSON string of tool_calls array
  createdAt    DateTime @default(now())

  taskRecord   TaskRecord @relation(fields: [taskRecordId], references: [id], onDelete: Cascade)

  @@index([taskRecordId, createdAt])
  @@index([taskRecordId, role])
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String   @unique
  storageState String   @default("{}")  // JSON string of Playwright storage state
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ScheduledJob {
  id              String    @id @default(uuid())
  userId          String
  name            String
  task            String
  cronExpression  String?
  runAt           DateTime?
  timezone        String    @default("UTC")
  nextRunAt       DateTime
  lastRunAt       DateTime?
  lastStatus      String?
  lastError       String?
  maxRetries      Int       @default(3)
  retryCount      Int       @default(0)
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, enabled, nextRunAt])
}
